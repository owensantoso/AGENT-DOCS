#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
base_ref=""
head_ref=""
message_file=""

usage() {
  cat <<'USAGE'
Usage: scripts/changelog-check [--repo PATH] [--base REF] [--head REF] [--message-file PATH]

Requires CHANGELOG.md to change when adopter-facing AGENT-DOCS surfaces change.
Use the explicit marker below in commit or PR text for changes that do not need
an adopter-facing record:

  Change-Record: not-needed
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      repo_root="$2"
      shift 2
      ;;
    --base)
      base_ref="$2"
      shift 2
      ;;
    --head)
      head_ref="$2"
      shift 2
      ;;
    --message-file)
      message_file="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "ERROR: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

cd "$repo_root"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "ERROR: changelog-check must run inside a git worktree" >&2
  exit 2
fi

change_record_marker="Change-Record: not-needed"

is_adopter_facing_path() {
  local path="$1"
  case "$path" in
    README.md|INSTALL.md|install.sh)
      return 0
      ;;
    scaffold/*|skills/*)
      return 0
      ;;
    scripts/agent-docs-init|scripts/changelog-check|scripts/docs-meta|scripts/release-check|scripts/README.md)
      return 0
      ;;
    guides/workflow-overview.md|guides/doc-types-and-responsibilities.md|guides/subagent-execution-loop.md|guides/adoption-checklist.md)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

changed_paths() {
  if [[ -n "$base_ref" || -n "$head_ref" ]]; then
    if [[ -z "$base_ref" || -z "$head_ref" ]]; then
      echo "ERROR: --base and --head must be provided together" >&2
      exit 2
    fi
    git diff --name-only "$base_ref" "$head_ref"
    return
  fi

  if [[ -n "${GITHUB_BASE_REF:-}" ]] &&
    git rev-parse --verify "origin/${GITHUB_BASE_REF}" >/dev/null 2>&1; then
    local merge_base
    merge_base="$(git merge-base "origin/${GITHUB_BASE_REF}" HEAD)"
    git diff --name-only "$merge_base" HEAD
    return
  fi

  git diff --name-only HEAD --
  git diff --cached --name-only
  git ls-files --others --exclude-standard
}

message_text() {
  if [[ -n "${CHANGELOG_CHECK_MESSAGE:-}" ]]; then
    printf '%s\n' "$CHANGELOG_CHECK_MESSAGE"
  fi

  if [[ -n "$message_file" ]]; then
    if [[ ! -f "$message_file" ]]; then
      echo "ERROR: message file does not exist: $message_file" >&2
      exit 2
    fi
    cat "$message_file"
    printf '\n'
  fi

  if [[ -n "$base_ref" && -n "$head_ref" ]]; then
    git log --format=%B "$base_ref..$head_ref"
    return
  fi

  if [[ -n "${GITHUB_BASE_REF:-}" ]] &&
    git rev-parse --verify "origin/${GITHUB_BASE_REF}" >/dev/null 2>&1; then
    local merge_base
    merge_base="$(git merge-base "origin/${GITHUB_BASE_REF}" HEAD)"
    git log --format=%B "$merge_base..HEAD"
  fi
}

changed=()
while IFS= read -r path; do
  changed+=("$path")
done < <(changed_paths | LC_ALL=C sort -u)

changelog_changed=false
adopter_paths=()
for path in "${changed[@]}"; do
  if [[ "$path" == "CHANGELOG.md" ]]; then
    changelog_changed=true
  fi
  if is_adopter_facing_path "$path"; then
    adopter_paths+=("$path")
  fi
done

if [[ "${#adopter_paths[@]}" -eq 0 ]]; then
  echo "No adopter-facing changes require a changelog entry."
  exit 0
fi

if "$changelog_changed"; then
  echo "CHANGELOG.md updated for adopter-facing changes."
  exit 0
fi

record_text="$(message_text)"
if grep -Fq "$change_record_marker" <<<"$record_text"; then
  echo "Adopter-facing changes exempted by $change_record_marker."
  exit 0
fi

{
  echo "ERROR: adopter-facing AGENT-DOCS surfaces changed without CHANGELOG.md."
  echo
  echo "Changed adopter-facing paths:"
  printf '  - %s\n' "${adopter_paths[@]}"
  echo
  echo "Add an adopter-facing entry to CHANGELOG.md, or include this marker in"
  echo "commit/PR text when no change record is needed:"
  echo
  echo "  $change_record_marker"
} >&2
exit 1
