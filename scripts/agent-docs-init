#!/usr/bin/env python3
"""Install an AGENT-DOCS scaffold profile into a target repository."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
import termios
import tty
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[1]
SCAFFOLD = REPO_ROOT / "scaffold"
ANSI_PATTERN = re.compile(r"\033\[[0-9;]*m")
ANSI_RESET = "\033[0m"
IMPORTANT_DOCS = {"AGENTS.md", "ARCHITECTURE.md", "CURRENT_STATE.md", "ROADMAP.md"}
IMPORTANT_FOLDERS = {("docs", "orientation")}
QUIET_FOLDERS = {("scripts",), ("tests",)}
DETAIL_LEFT_WIDTH = 52
DETAIL_GAP = 4
AGENT_DOCS_OWNED_PATHS = {
    Path("scripts/docs-meta"),
    Path("tests/docs-meta-smoke.sh"),
}
MANIFEST_PATH = Path(".agent-docs/manifest.json")
DOCS_META_UPDATE_GENERATOR = "scripts/docs-meta update"
DOCS_META_UPDATE_OUTPUTS = {
    Path("docs/IDEAS.md"),
    Path("docs/CONCEPTS.md"),
    Path("docs/SPECS.md"),
    Path("docs/LEARNINGS.md"),
    Path("docs/EXPLAINERS.md"),
    Path("docs/QUESTIONS.md"),
    Path("docs/DOCS-REGISTRY.md"),
    Path("docs/TODOS.md"),
    Path("docs/AREAS.md"),
    Path("docs/AUDITS.md"),
    Path("docs/ROADMAP-VIEW.md"),
}


@dataclass(frozen=True)
class Profile:
    key: str
    label: str
    summary: str
    template_summary: str
    template_groups: tuple[tuple[str, tuple[tuple[str, str], ...]], ...]
    implications: tuple[str, ...]
    structure: tuple[str, ...]
    docs_meta_default: bool


PROFILES = {
