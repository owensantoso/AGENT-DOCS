#!/usr/bin/env python3
"""AGENT-DOCS command entry point."""

from __future__ import annotations

import argparse
import hashlib
import importlib.util
import importlib.machinery
import json
import os
import re
import shutil
import stat
import subprocess
import sys
from dataclasses import dataclass, field
from datetime import datetime, timezone
from pathlib import Path
from tempfile import NamedTemporaryFile


SCRIPT_DIR = Path(__file__).resolve().parent
MANIFEST_PATH = Path(".agent-docs/manifest.json")
SHA256_PATTERN = re.compile(r"^[0-9a-f]{64}$")
KNOWN_OPTIONAL_COMPONENTS = {"docs-meta"}


@dataclass
class Finding:
    path: str
    reason: str


@dataclass
class Report:
    target: Path
    profile: str | None = None
    optional_components: list[str] = field(default_factory=list)
    source_commit: str | None = None
    installed_at: str | None = None
    updated_at: str | None = None
    categories: dict[str, list[Finding]] = field(default_factory=dict)

    def add(self, category: str, path: str | Path, reason: str) -> None:
        self.categories.setdefault(category, []).append(Finding(sanitize_text(Path(path).as_posix()), sanitize_text(reason)))

    def has_any(self, categories: set[str]) -> bool:
        return any(self.categories.get(category) for category in categories)


@dataclass
class ToolingOperation:
    kind: str
    relpath: Path
    action: object
    record: dict | None
    backup_relpath: Path | None = None


WARNING_CATEGORIES = {
    "missing manifest/legacy/manual review",
    "missing AGENT-DOCS-owned tooling",
    "checksum drift/local modification",
    "candidate tooling updates available",
    "safe automatic additions",
    "generated view refreshes",
    "missing project-owned manifest records",
}
REFUSED_CATEGORIES = {"refused/unknown/incompatible shapes"}
BASELINE_REFUSED_CATEGORIES = {"manual-review/refused"}


def print_help() -> None:
    print(
        """Usage: agent-docs <command> [args]

Commands:
  init      Install an AGENT-DOCS scaffold profile into a target repository.
  docs      Run deterministic docs operations. Preferred namespace for docs-meta.
  doctor    Read-only install and drift report.
  upgrade   Safe upgrade preview, or --write --tooling-only for owned tooling.
  baseline  Preview or create a manifest for a conservative legacy install.

Exit codes:
  0 healthy/current
  1 warnings or actionable drift
  2 invalid usage, refused, unknown, or incompatible shapes
"""
    )


def load_init_module():
    init_path = SCRIPT_DIR / "agent-docs-init"
    loader = importlib.machinery.SourceFileLoader("agent_docs_init", str(init_path))
    spec = importlib.util.spec_from_loader("agent_docs_init", loader)
    if spec is None or spec.loader is None:
        raise RuntimeError(f"Could not load {init_path}")
    module = importlib.util.module_from_spec(spec)
    sys.modules[spec.name] = module
    previous_dont_write_bytecode = sys.dont_write_bytecode
    sys.dont_write_bytecode = True
    try:
        spec.loader.exec_module(module)
    finally:
        sys.dont_write_bytecode = previous_dont_write_bytecode
    return module


def checksum(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def action_checksum(action) -> str:
    if action.source:
        data = action.source.read_bytes()
    else:
        data = (action.content or "").encode("utf-8")
    return hashlib.sha256(data).hexdigest()


def action_content(action) -> bytes:
    if action.source:
        return action.source.read_bytes()
    return (action.content or "").encode("utf-8")


def safe_manifest_relpath(value: object) -> Path | None:
    if not isinstance(value, str) or not value:
        return None
    relpath = Path(value)
    if relpath == Path(".") or relpath.is_absolute() or ".." in relpath.parts:
        return None
    return relpath


def target_path(target: Path, relpath: Path) -> Path:
    return target / relpath


def existing_symlink_in_target_path(target: Path, relpath: Path) -> Path | None:
    current = target
    for index, part in enumerate(relpath.parts):
        current = current / part
        if current.is_symlink():
            return Path(*relpath.parts[: index + 1])
    return None


def existing_non_directory_parent_in_target_path(target: Path, relpath: Path) -> Path | None:
    current = target
    for index, part in enumerate(relpath.parts[:-1]):
        current = current / part
        if current.exists() and not current.is_dir():
            return Path(*relpath.parts[: index + 1])
    return None


def valid_sha256(value: object) -> bool:
    return isinstance(value, str) and SHA256_PATTERN.fullmatch(value) is not None


def sanitize_text(value: object) -> str:
    text = str(value)
    sanitized = []
    for char in text:
        code = ord(char)
        if code < 32 or code == 127:
            sanitized.append(f"\\x{code:02x}")
        else:
            sanitized.append(char)
    return "".join(sanitized)


def safe_checksum(path: Path) -> tuple[str | None, str | None]:
    try:
        if not path.is_file():
            return None, "path is not a regular file"
        return checksum(path), None
    except OSError as error:
        return None, f"could not read file for checksum: {error}"


def utc_timestamp() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def backup_timestamp() -> str:
    return datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def action_mode(action) -> str:
    return "755" if action.executable else "644"


def expected_mode_value(action) -> int:
    return 0o755 if action.executable else 0o644


def file_mode(path: Path) -> str:
    return f"{stat.S_IMODE(path.stat().st_mode):03o}"


def current_source_metadata(init_module) -> dict:
    return {
        "repository": init_module.git_output(["config", "--get", "remote.origin.url"]),
        "ref": init_module.git_output(["symbolic-ref", "--quiet", "--short", "HEAD"]),
        "commit": init_module.git_output(["rev-parse", "--verify", "HEAD"]),
        "path": str(init_module.REPO_ROOT),
    }


def source_metadata_for_action(action) -> dict:
    return {
        "type": "agent-docs-action",
        "path": action.relpath.as_posix(),
    }


def optional_components_for_docs_meta(profile, docs_meta: str) -> list[str]:
    include_docs_meta = profile.docs_meta_default if docs_meta == "auto" else docs_meta == "yes"
    return ["docs-meta"] if include_docs_meta else []


def update_owned_record(record: dict, action) -> None:
    record["checksum_sha256"] = action_checksum(action)
    record["mode"] = action_mode(action)
    record["source"] = source_metadata_for_action(action)


def atomic_write_bytes(destination: Path, data: bytes, executable: bool) -> None:
    destination.parent.mkdir(parents=True, exist_ok=True)
    temp_path: str | None = None
    try:
        with NamedTemporaryFile("wb", dir=destination.parent, prefix=f".{destination.name}.", delete=False) as temp_file:
            temp_file.write(data)
            temp_path = temp_file.name
        temp = Path(temp_path)
        temp.chmod(0o755 if executable else 0o644)
        os.replace(temp, destination)
    finally:
        if temp_path is not None:
            try:
                Path(temp_path).unlink()
            except FileNotFoundError:
                pass


def atomic_write_json(destination: Path, data: dict) -> None:
    atomic_write_bytes(
        destination,
        (json.dumps(data, indent=2, sort_keys=True) + "\n").encode("utf-8"),
        executable=False,
    )


def backup_destination_refusal(target: Path, backup_root: Path, relpath: Path) -> Finding | None:
    backup = backup_root / relpath
    backup_relpath = backup.relative_to(target)
    symlink_relpath = existing_symlink_in_target_path(target, backup_relpath)
    if symlink_relpath is not None:
        return Finding(
            backup_relpath.as_posix(),
            f"backup destination would traverse existing symlink inside target: {symlink_relpath}",
        )
    non_directory_parent = existing_non_directory_parent_in_target_path(target, backup_relpath)
    if non_directory_parent is not None:
        return Finding(
            backup_relpath.as_posix(),
            f"backup destination parent is not a directory: {non_directory_parent}",
        )
    try:
        target_resolved = target.resolve()
        backup_resolved = backup.resolve(strict=False)
        backup_resolved.relative_to(target_resolved)
    except (OSError, ValueError) as error:
        return Finding(backup_relpath.as_posix(), f"backup destination resolves outside target: {error}")
    return None


def backup_existing_file(target: Path, backup_root: Path, relpath: Path) -> Path:
    refusal = backup_destination_refusal(target, backup_root, relpath)
    if refusal is not None:
        raise RuntimeError(refusal.reason)
    source = target / relpath
    backup = backup_root / relpath
    backup.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(source, backup)
    return backup.relative_to(target)


def backup_root_refusal(target: Path, backup_root: Path) -> Finding | None:
    relpath = backup_root.relative_to(target)
    symlink_relpath = existing_symlink_in_target_path(target, relpath)
    if symlink_relpath is not None:
        return Finding(
            relpath.as_posix(),
            f"backup path would traverse existing symlink inside target: {symlink_relpath}",
        )
    non_directory_parent = existing_non_directory_parent_in_target_path(target, relpath)
    if non_directory_parent is not None:
        return Finding(
            relpath.as_posix(),
            f"backup path parent is not a directory: {non_directory_parent}",
        )
    try:
        target_resolved = target.resolve()
        backup_resolved = backup_root.resolve(strict=False)
        backup_resolved.relative_to(target_resolved)
    except (OSError, ValueError) as error:
        return Finding(relpath.as_posix(), f"backup path resolves outside target: {error}")
    return None


def read_manifest(report: Report) -> dict | None:
    manifest_path = report.target / MANIFEST_PATH
    symlink_relpath = existing_symlink_in_target_path(report.target, MANIFEST_PATH)
    if symlink_relpath is not None:
        report.add(
            "refused/unknown/incompatible shapes",
            MANIFEST_PATH,
            f"path would traverse existing symlink inside target: {symlink_relpath}",
        )
        return None
    if not manifest_path.exists():
        report.add(
            "missing manifest/legacy/manual review",
            MANIFEST_PATH,
            "manifest is missing; legacy installs remain manual-review until a deliberate baseline path exists",
        )
        if (report.target / "AGENTS.md").exists() or (report.target / "docs").exists():
            report.add(
                "project-owned/manual-review items",
                ".",
                "target has AGENT-DOCS-shaped files but no manifest to prove ownership",
            )
        return None
    try:
        manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as error:
        report.add("refused/unknown/incompatible shapes", MANIFEST_PATH, f"manifest is not valid JSON: {error}")
        return None
    if not isinstance(manifest, dict):
        report.add(
            "refused/unknown/incompatible shapes",
            MANIFEST_PATH,
            "manifest root must be a JSON object",
        )
        return None
    if manifest.get("schema_version") != 1:
        report.add(
            "refused/unknown/incompatible shapes",
            MANIFEST_PATH,
            f"unsupported manifest schema_version {manifest.get('schema_version')!r}; expected 1",
        )
        return None
    return manifest


def classify_target(target: Path) -> Report:
    report = Report(target=target.resolve())
    if not report.target.exists():
        report.add("refused/unknown/incompatible shapes", report.target, "target path does not exist")
        return report
    if not report.target.is_dir():
        report.add("refused/unknown/incompatible shapes", report.target, "target path is not a directory")
        return report

    manifest = read_manifest(report)
    if manifest is None:
        return report

    report.profile = manifest.get("profile") if isinstance(manifest.get("profile"), str) else None
    optional_components = manifest.get("optional_components", [])
    if isinstance(optional_components, list):
        report.optional_components = [item for item in optional_components if isinstance(item, str)]
        for index, item in enumerate(optional_components):
            if not isinstance(item, str):
                report.add("refused/unknown/incompatible shapes", f"optional_components[{index}]", "optional component must be a string")
                continue
            if item not in KNOWN_OPTIONAL_COMPONENTS:
                report.add("refused/unknown/incompatible shapes", item, "unknown optional component")
    else:
        report.add("refused/unknown/incompatible shapes", "optional_components", "manifest optional_components field is not a list")
    source = manifest.get("source", {})
    if isinstance(source, dict):
        report.source_commit = source.get("commit") if isinstance(source.get("commit"), str) else None
    report.installed_at = manifest.get("installed_at") if isinstance(manifest.get("installed_at"), str) else None
    report.updated_at = manifest.get("updated_at") if isinstance(manifest.get("updated_at"), str) else None

    init_module = load_init_module()
    upstream_actions = {}
    if report.profile in init_module.PROFILES:
        profile = init_module.PROFILES[report.profile]
        include_docs_meta = "docs-meta" in report.optional_components
        upstream_actions = {
            action.relpath.as_posix(): action
            for action in init_module.profile_actions(profile, include_docs_meta)
            if init_module.action_ownership(action) == "agent-docs-owned"
        }
    else:
        report.add(
            "refused/unknown/incompatible shapes",
            "profile",
            f"unknown profile {report.profile!r}; cannot compare against upstream actions",
        )

    seen_paths: set[str] = set()
    files = manifest.get("files", [])
    if not isinstance(files, list):
        report.add("refused/unknown/incompatible shapes", "files", "manifest files field is not a list")
        files = []

    for index, record in enumerate(files):
        if not isinstance(record, dict):
            report.add("refused/unknown/incompatible shapes", f"files[{index}]", "manifest file record is not an object")
            continue
        relpath = safe_manifest_relpath(record.get("path"))
        if relpath is None:
            report.add(
                "refused/unknown/incompatible shapes",
                str(record.get("path")),
                "manifest path must be a non-empty relative path inside the target repo",
            )
            continue
        rel = relpath.as_posix()
        if rel in seen_paths:
            report.add("refused/unknown/incompatible shapes", relpath, "duplicate manifest file record")
            continue
        seen_paths.add(rel)
        ownership = record.get("ownership")
        destination = target_path(report.target, relpath)
        symlink_relpath = existing_symlink_in_target_path(report.target, relpath)
        if symlink_relpath is not None:
            report.add(
                "refused/unknown/incompatible shapes",
                relpath,
                f"path would traverse existing symlink inside target: {symlink_relpath}",
            )
            continue
        non_directory_parent = existing_non_directory_parent_in_target_path(report.target, relpath)
        if non_directory_parent is not None:
            report.add(
                "refused/unknown/incompatible shapes",
                relpath,
                f"path parent is not a directory: {non_directory_parent}",
            )
            continue

        if ownership == "agent-docs-owned":
            manifest_checksum = record.get("checksum_sha256")
            if not valid_sha256(manifest_checksum):
                report.add(
                    "refused/unknown/incompatible shapes",
                    relpath,
                    "agent-docs-owned checksum_sha256 must be 64 lowercase hex characters",
                )
                continue
            upstream_action = upstream_actions.get(rel)
            if upstream_action is None:
                report.add(
                    "refused/unknown/incompatible shapes",
                    relpath,
                    "agent-docs-owned file is not known in this AGENT-DOCS version",
                )
                continue
            manifest_mode = record.get("mode")
            if not isinstance(manifest_mode, str):
                report.add(
                    "refused/unknown/incompatible shapes",
                    relpath,
                    "agent-docs-owned mode must be recorded as a string",
                )
                continue
            if manifest_mode != action_mode(upstream_action):
                report.add(
                    "refused/unknown/incompatible shapes",
                    relpath,
                    f"agent-docs-owned mode must be {action_mode(upstream_action)!r} for this upstream action",
                )
                continue
            if not destination.exists():
                report.add("missing AGENT-DOCS-owned tooling", relpath, "manifest records this owned file, but it is missing")
                report.add("safe automatic additions", relpath, "missing owned tooling can be restored from AGENT-DOCS upstream")
                continue
            current_checksum, checksum_error = safe_checksum(destination)
            if checksum_error is not None or current_checksum is None:
                report.add("refused/unknown/incompatible shapes", relpath, f"owned {checksum_error}")
                continue
            if current_checksum != manifest_checksum:
                report.add(
                    "checksum drift/local modification",
                    relpath,
                    "current checksum differs from manifest; requires manual review before any automatic update",
                )
                continue
            if file_mode(destination) != manifest_mode and not (upstream_action.executable and not os.access(destination, os.X_OK)):
                report.add(
                    "checksum drift/local modification",
                    relpath,
                    f"current mode {file_mode(destination)} differs from manifest mode {manifest_mode}",
                )
                continue
            if upstream_action.executable and not os.access(destination, os.X_OK):
                report.add(
                    "checksum drift/local modification",
                    relpath,
                    "current file matches manifest checksum but is missing executable bit",
                )
                continue
            if action_checksum(upstream_action) != manifest_checksum:
                report.add(
                    "candidate tooling updates available",
                    relpath,
                    "current file matches manifest base and AGENT-DOCS upstream has different content",
                )
            else:
                report.add("healthy/current", relpath, "owned file exists and matches manifest checksum")
        elif ownership == "project-owned-after-install":
            if destination.exists():
                if not destination.is_file():
                    report.add("refused/unknown/incompatible shapes", relpath, "project-owned path is not a regular file")
                    continue
                report.add(
                    "project-owned/manual-review items",
                    relpath,
                    "project-owned after install; doctor and dry-run will not overwrite it",
                )
            else:
                report.add(
                    "missing project-owned manifest records",
                    relpath,
                    "project-owned manifest record is missing; recreate or remove intentionally after review",
                )
        else:
            report.add("refused/unknown/incompatible shapes", relpath, f"unknown ownership {ownership!r}")

    for rel, upstream_action in sorted(upstream_actions.items()):
        if rel in seen_paths:
            continue
        destination = report.target / upstream_action.relpath
        symlink_relpath = existing_symlink_in_target_path(report.target, upstream_action.relpath)
        if symlink_relpath is not None:
            report.add(
                "refused/unknown/incompatible shapes",
                upstream_action.relpath,
                f"path would traverse existing symlink inside target: {symlink_relpath}",
            )
            continue
        non_directory_parent = existing_non_directory_parent_in_target_path(report.target, upstream_action.relpath)
        if non_directory_parent is not None:
            report.add(
                "refused/unknown/incompatible shapes",
                upstream_action.relpath,
                f"path parent is not a directory: {non_directory_parent}",
            )
            continue
        if destination.exists():
            report.add(
                "refused/unknown/incompatible shapes",
                upstream_action.relpath,
                "AGENT-DOCS-owned upstream file exists but is absent from the manifest",
            )
        else:
            report.add(
                "safe automatic additions",
                upstream_action.relpath,
                "AGENT-DOCS-owned upstream file is missing and has no target path conflict",
            )

    generated_views = manifest.get("generated_views", [])
    if not isinstance(generated_views, list):
        report.add("refused/unknown/incompatible shapes", "generated_views", "manifest generated_views field is not a list")
        generated_views = []
    for index, record in enumerate(generated_views):
        if not isinstance(record, dict):
            report.add("refused/unknown/incompatible shapes", f"generated_views[{index}]", "generated view record is not an object")
            continue
        relpath = safe_manifest_relpath(record.get("path"))
        if relpath is None:
            report.add(
                "refused/unknown/incompatible shapes",
                str(record.get("path")),
                "generated view path must be a non-empty relative path inside the target repo",
            )
            continue
        symlink_relpath = existing_symlink_in_target_path(report.target, relpath)
        if symlink_relpath is not None:
            report.add(
                "refused/unknown/incompatible shapes",
                relpath,
                f"path would traverse existing symlink inside target: {symlink_relpath}",
            )
            continue
        non_directory_parent = existing_non_directory_parent_in_target_path(report.target, relpath)
        if non_directory_parent is not None:
            report.add(
                "refused/unknown/incompatible shapes",
                relpath,
                f"path parent is not a directory: {non_directory_parent}",
            )
            continue
        destination = report.target / relpath
        view_checksum = record.get("checksum_sha256")
        generator = record.get("generator", "unknown generator")
        if view_checksum is None:
            report.add(
                "refused/unknown/incompatible shapes",
                relpath,
                "generated view checksum_sha256 must be present",
            )
            continue
        if not valid_sha256(view_checksum):
            report.add(
                "refused/unknown/incompatible shapes",
                relpath,
                "generated view checksum_sha256 must be 64 lowercase hex characters",
            )
            continue
        if not destination.exists():
            report.add("generated view refreshes", relpath, f"generated view is missing; refresh with {generator}")
        else:
            current_checksum, checksum_error = safe_checksum(destination)
            if checksum_error is not None or current_checksum is None:
                report.add("refused/unknown/incompatible shapes", relpath, f"generated view {checksum_error}")
                continue
            if current_checksum != view_checksum:
                report.add("generated view refreshes", relpath, f"generated view checksum differs; refresh with {generator}")

    return report


def report_exit_code(report: Report) -> int:
    if report.has_any(REFUSED_CATEGORIES):
        return 2
    if report.has_any(WARNING_CATEGORIES):
        return 1
    return 0


def status_label(report: Report) -> str:
    code = report_exit_code(report)
    if code == 0:
        return "healthy/current"
    if code == 1:
        return "warnings/actionable drift"
    return "incompatible/refused/invalid usage"


def print_report(command: str, report: Report) -> None:
    print(f"AGENT-DOCS {command}")
    print(f"Target: {report.target}")
    print(f"Status: {status_label(report)}")
    if report.profile:
        print(f"Profile: {sanitize_text(report.profile)}")
    if report.optional_components:
        print(f"Optional components: {sanitize_text(', '.join(report.optional_components))}")
    if report.source_commit:
        print(f"Source commit: {sanitize_text(report.source_commit)}")
    if report.installed_at:
        print(f"Installed at: {sanitize_text(report.installed_at)}")
    if report.updated_at:
        print(f"Updated at: {sanitize_text(report.updated_at)}")
    print("")

    category_order = [
        "healthy/current",
        "missing manifest/legacy/manual review",
        "missing AGENT-DOCS-owned tooling",
        "checksum drift/local modification",
        "candidate tooling updates available",
        "safe automatic additions",
        "generated view refreshes",
        "missing project-owned manifest records",
        "project-owned/manual-review items",
        "refused/unknown/incompatible shapes",
    ]
    for category in category_order:
        findings = report.categories.get(category, [])
        if not findings:
            continue
        print(f"{category}:")
        for finding in findings:
            print(f"- {finding.path}: {finding.reason}")
        print("")

    print("Recommended next commands:")
    if report_exit_code(report) == 0:
        print(f"- agent-docs doctor {report.target}")
        print(f"- agent-docs upgrade --dry-run {report.target}")
    elif report.categories.get("missing manifest/legacy/manual review"):
        print(f"- agent-docs init {report.target} --profile small --dry-run")
        print("- Review legacy files manually before creating any future baseline manifest.")
    elif report_exit_code(report) == 1:
        print(f"- agent-docs upgrade --dry-run {report.target}")
        print("- Review checksum drift and project-owned/manual-review items before any future write mode.")
    else:
        print(f"- agent-docs doctor {report.target}")
        print("- Fix refused/unknown/incompatible manifest records before retrying.")


def baseline_exit_code(report: Report) -> int:
    if report.has_any(BASELINE_REFUSED_CATEGORIES):
        return 2
    return 0


def baseline_status_label(report: Report) -> str:
    if baseline_exit_code(report) == 0:
        return "healthy/current"
    return "incompatible/refused/invalid usage"


def print_baseline_report(command: str, report: Report) -> None:
    print(f"AGENT-DOCS baseline {command}")
    print(f"Target: {report.target}")
    print(f"Status: {baseline_status_label(report)}")
    if report.profile:
        print(f"Profile: {sanitize_text(report.profile)}")
    if report.optional_components:
        print(f"Optional components: {sanitize_text(', '.join(report.optional_components))}")
    print("")

    for category in [
        "baseline owned tooling",
        "project-owned after install",
        "manual-review/refused",
    ]:
        findings = report.categories.get(category, [])
        if not findings:
            continue
        print(f"{category}:")
        for finding in findings:
            print(f"- {finding.path}: {finding.reason}")
        print("")


def baseline_record_for_action(action, ownership: str) -> dict:
    record = {
        "path": action.relpath.as_posix(),
        "ownership": ownership,
    }
    if ownership == "agent-docs-owned":
        update_owned_record(record, action)
    return record


def path_inside_target(target: Path, relpath: Path) -> bool:
    try:
        target_resolved = target.resolve()
        destination_resolved = (target / relpath).resolve(strict=False)
        destination_resolved.relative_to(target_resolved)
    except (OSError, ValueError):
        return False
    return True


def build_baseline(target_arg: Path, profile_key: str, docs_meta: str) -> tuple[Report, dict | None]:
    init_module = load_init_module()
    profile = init_module.PROFILES[profile_key]
    optional_components = optional_components_for_docs_meta(profile, docs_meta)
    include_docs_meta = "docs-meta" in optional_components
    raw_target = target_arg.expanduser()
    target = raw_target.resolve() if raw_target.exists() else raw_target.absolute()
    report = Report(target=target, profile=profile.key, optional_components=optional_components)

    if not raw_target.exists():
        report.add("manual-review/refused", target, "target path does not exist")
        return report, None
    if raw_target.is_symlink():
        report.add("manual-review/refused", ".", "target path is a symlink")
        return report, None
    if not raw_target.is_dir():
        report.add("manual-review/refused", target, "target path is not a directory")
        return report, None

    manifest_symlink = existing_symlink_in_target_path(target, MANIFEST_PATH)
    if manifest_symlink is not None:
        report.add(
            "manual-review/refused",
            MANIFEST_PATH,
            f"manifest path would traverse existing symlink inside target: {manifest_symlink}",
        )
    manifest_parent_conflict = existing_non_directory_parent_in_target_path(target, MANIFEST_PATH)
    if manifest_parent_conflict is not None:
        report.add(
            "manual-review/refused",
            MANIFEST_PATH,
            f"manifest path parent is not a directory: {manifest_parent_conflict}",
        )
    if (target / MANIFEST_PATH).exists():
        report.add(
            "manual-review/refused",
            MANIFEST_PATH,
            "Refusing to baseline target with existing manifest; use agent-docs doctor or upgrade instead",
        )

    records: list[dict] = []
    seen_paths: set[str] = set()
    actions = init_module.profile_actions(profile, include_docs_meta)
    selected_owned_paths = {
        action.relpath
        for action in actions
        if init_module.action_ownership(action) == "agent-docs-owned"
    }
    for action in actions:
        relpath = safe_manifest_relpath(action.relpath.as_posix())
        if relpath is None:
            report.add(
                "manual-review/refused",
                action.relpath,
                "upstream action path is not a safe relative path inside the target",
            )
            continue
        rel = relpath.as_posix()
        if rel in seen_paths:
            report.add("manual-review/refused", relpath, "duplicate upstream action path")
            continue
        seen_paths.add(rel)

        ownership = init_module.action_ownership(action)
        destination = target / relpath
        symlink_relpath = existing_symlink_in_target_path(target, relpath)
        if symlink_relpath is not None:
            report.add(
                "manual-review/refused",
                relpath,
                f"path would traverse existing symlink inside target: {symlink_relpath}",
            )
            continue
        non_directory_parent = existing_non_directory_parent_in_target_path(target, relpath)
        if non_directory_parent is not None:
            report.add(
                "manual-review/refused",
                relpath,
                f"path parent is not a directory: {non_directory_parent}",
            )
            continue
        if not path_inside_target(target, relpath):
            report.add("manual-review/refused", relpath, "path would resolve outside target")
            continue

        if ownership == "agent-docs-owned":
            if not destination.exists():
                report.add(
                    "manual-review/refused",
                    relpath,
                    "missing owned tooling; baseline requires the current upstream file to be present",
                )
                continue
            if not destination.is_file():
                report.add("manual-review/refused", relpath, "owned path is not a regular file")
                continue
            try:
                link_count = destination.stat().st_nlink
            except OSError as error:
                report.add("manual-review/refused", relpath, f"owned stat failed: {error}")
                continue
            if link_count > 1:
                report.add(
                    "manual-review/refused",
                    relpath,
                    f"owned path has multiple hardlinks ({link_count}); baseline requires an unshared file",
                )
                continue
            current_checksum, checksum_error = safe_checksum(destination)
            if checksum_error is not None or current_checksum is None:
                report.add("manual-review/refused", relpath, f"owned {checksum_error}")
                continue
            upstream_checksum = action_checksum(action)
            if current_checksum != upstream_checksum:
                report.add(
                    "manual-review/refused",
                    relpath,
                    "checksum differs from upstream action; baseline refuses locally modified owned tooling",
                )
                continue
            expected_mode = action_mode(action)
            current_mode = file_mode(destination)
            if current_mode != expected_mode:
                report.add(
                    "manual-review/refused",
                    relpath,
                    f"mode {current_mode} differs from expected mode {expected_mode}",
                )
                continue
            records.append(baseline_record_for_action(action, ownership))
            report.add("baseline owned tooling", relpath, "known AGENT-DOCS-owned file matches upstream checksum and mode")
            continue

        if destination.exists():
            if not destination.is_file():
                report.add("manual-review/refused", relpath, "project-owned path is not a regular file")
                continue
            records.append(baseline_record_for_action(action, ownership))
            report.add("project-owned after install", relpath, "present starter/project file will be recorded without checksum")

    for relpath in sorted(init_module.AGENT_DOCS_OWNED_PATHS):
        if relpath in selected_owned_paths:
            continue
        symlink_relpath = existing_symlink_in_target_path(target, relpath)
        if symlink_relpath is not None:
            report.add(
                "manual-review/refused",
                relpath,
                f"known AGENT-DOCS-owned path is not selected and would traverse existing symlink inside target: {symlink_relpath}",
            )
            continue
        non_directory_parent = existing_non_directory_parent_in_target_path(target, relpath)
        if non_directory_parent is not None:
            report.add(
                "manual-review/refused",
                relpath,
                f"known AGENT-DOCS-owned path is not selected and has non-directory parent: {non_directory_parent}",
            )
            continue
        if (target / relpath).exists():
            report.add(
                "manual-review/refused",
                relpath,
                "known AGENT-DOCS-owned path exists but is not selected by profile/options",
            )

    if not records:
        report.add(
            "manual-review/refused",
            ".",
            "no selected AGENT-DOCS files found; baseline refuses empty or unrelated targets",
        )

    if baseline_exit_code(report) != 0:
        return report, None

    timestamp = utc_timestamp()
    manifest = {
        "schema_version": 1,
        "installed_at": timestamp,
        "updated_at": timestamp,
        "source": current_source_metadata(init_module),
        "profile": profile.key,
        "optional_components": optional_components,
        "files": records,
        "generated_views": [],
    }
    return report, manifest


def baseline(args: list[str]) -> int:
    init_module = load_init_module()
    parser = argparse.ArgumentParser(
        prog="agent-docs baseline",
        description="Preview or create a manifest for a conservative legacy AGENT-DOCS install.",
    )
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument("--dry-run", action="store_true", help="Preview without writing. This is the default.")
    mode.add_argument("--write", action="store_true", help="Create .agent-docs/manifest.json after safety checks pass.")
    parser.add_argument("target", nargs="?", type=Path, default=Path.cwd(), help="Target repository root. Defaults to the current directory.")
    parser.add_argument("--profile", required=True, choices=sorted(init_module.PROFILES), help="Installed scaffold profile to baseline.")
    parser.add_argument(
        "--docs-meta",
        choices=["auto", "yes", "no"],
        default="auto",
        help="Whether docs-meta tooling should be part of the selected profile. Default: profile-specific.",
    )
    parsed = parser.parse_args(args)

    report, manifest = build_baseline(parsed.target, parsed.profile, parsed.docs_meta)
    print_baseline_report("write" if parsed.write else "dry-run", report)
    if baseline_exit_code(report) != 0:
        if parsed.write:
            print("Refusing to write baseline manifest: manual-review/refused items are present.", file=sys.stderr)
        return baseline_exit_code(report)
    if not parsed.write:
        print(f"Dry run only. Re-run with --write to create {MANIFEST_PATH}.")
        return 0
    if manifest is None:
        print("Refusing to write baseline manifest: manifest data is unavailable.", file=sys.stderr)
        return 2
    manifest_path = report.target / MANIFEST_PATH
    if manifest_path.exists() or existing_symlink_in_target_path(report.target, MANIFEST_PATH) is not None:
        print("Refusing to write baseline manifest: manifest path became unsafe or already exists.", file=sys.stderr)
        return 2
    try:
        atomic_write_json(manifest_path, manifest)
    except OSError as error:
        print(f"Refusing to write baseline manifest: {error}", file=sys.stderr)
        return 2
    print(f"Created: {MANIFEST_PATH}")
    return 0


def doctor(args: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="agent-docs doctor", description="Read-only install and drift report.")
    parser.add_argument("target", nargs="?", type=Path, default=Path.cwd(), help="Target repository root. Defaults to the current directory.")
    parsed = parser.parse_args(args)
    report = classify_target(parsed.target.expanduser())
    print_report("doctor", report)
    return report_exit_code(report)


def manifest_and_upstream_actions(target: Path, report: Report) -> tuple[dict | None, dict[str, object], object | None]:
    manifest = read_manifest(report)
    if manifest is None:
        return None, {}, None
    init_module = load_init_module()
    profile_key = manifest.get("profile") if isinstance(manifest.get("profile"), str) else None
    optional_components = manifest.get("optional_components", [])
    include_docs_meta = isinstance(optional_components, list) and "docs-meta" in optional_components
    if profile_key not in init_module.PROFILES:
        return manifest, {}, init_module
    profile = init_module.PROFILES[profile_key]
    return (
        manifest,
        {
            action.relpath.as_posix(): action
            for action in init_module.profile_actions(profile, include_docs_meta)
            if init_module.action_ownership(action) == "agent-docs-owned"
        },
        init_module,
    )


def build_tooling_operations(report: Report) -> tuple[list[ToolingOperation], list[Finding], dict | None, object | None]:
    validation_report = Report(target=report.target)
    manifest, upstream_actions, init_module = manifest_and_upstream_actions(report.target, validation_report)
    if manifest is None:
        return [], [finding for findings in validation_report.categories.values() for finding in findings], None, init_module

    operations: list[ToolingOperation] = []
    blocking_drift: list[Finding] = []
    seen_paths: set[str] = set()
    files = manifest.get("files", [])
    if not isinstance(files, list):
        return [], [Finding("files", "manifest files field is not a list")], manifest, init_module

    for record in files:
        if not isinstance(record, dict):
            continue
        relpath = safe_manifest_relpath(record.get("path"))
        if relpath is None:
            continue
        rel = relpath.as_posix()
        seen_paths.add(rel)
        if record.get("ownership") != "agent-docs-owned":
            continue
        action = upstream_actions.get(rel)
        if action is None:
            continue
        manifest_checksum = record.get("checksum_sha256")
        if not valid_sha256(manifest_checksum):
            continue
        manifest_mode = record.get("mode")
        if not isinstance(manifest_mode, str):
            blocking_drift.append(
                Finding(
                    relpath.as_posix(),
                    "agent-docs-owned mode must be recorded as a string",
                )
            )
            continue
        if manifest_mode != action_mode(action):
            blocking_drift.append(
                Finding(
                    relpath.as_posix(),
                    f"manifest mode {manifest_mode!r} does not match expected mode {action_mode(action)!r}",
                )
            )
            continue
        destination = report.target / relpath
        if not destination.exists():
            operations.append(ToolingOperation("restore", relpath, action, record))
            continue
        current_checksum, checksum_error = safe_checksum(destination)
        if checksum_error is not None or current_checksum is None:
            continue
        if current_checksum != manifest_checksum:
            blocking_drift.append(
                Finding(
                    relpath.as_posix(),
                    "current checksum differs from manifest; refusing tooling-only write",
                )
            )
            continue
        if file_mode(destination) != manifest_mode:
            if action.executable and not os.access(destination, os.X_OK):
                operations.append(ToolingOperation("chmod", relpath, action, record))
            else:
                blocking_drift.append(
                    Finding(
                        relpath.as_posix(),
                        f"current mode {file_mode(destination)} differs from manifest mode {manifest_mode}",
                    )
                )
            continue
        upstream_checksum = action_checksum(action)
        if upstream_checksum != manifest_checksum:
            operations.append(ToolingOperation("update", relpath, action, record))
        elif action.executable and not os.access(destination, os.X_OK):
            operations.append(ToolingOperation("chmod", relpath, action, record))

    for rel, action in sorted(upstream_actions.items()):
        if rel in seen_paths:
            continue
        destination = report.target / action.relpath
        if not destination.exists():
            operations.append(ToolingOperation("add", action.relpath, action, None))

    return operations, blocking_drift, manifest, init_module


def write_audit(backup_root: Path, operations: list[ToolingOperation]) -> None:
    audit = {
        "created_at": utc_timestamp(),
        "operation": "agent-docs upgrade --write --tooling-only",
        "touched": [
            {
                "path": operation.relpath.as_posix(),
                "kind": operation.kind,
                "backup": operation.backup_relpath.as_posix() if operation.backup_relpath else None,
            }
            for operation in operations
        ],
    }
    atomic_write_json(backup_root / "audit.json", audit)


def apply_tooling_operations(report: Report, operations: list[ToolingOperation], manifest: dict, init_module, backup_root: Path) -> None:
    backup_root.mkdir(parents=True, exist_ok=True)
    if (report.target / MANIFEST_PATH).is_file():
        backup_existing_file(report.target, backup_root, MANIFEST_PATH)

    files = manifest.setdefault("files", [])
    for operation in operations:
        destination = report.target / operation.relpath
        if operation.kind in {"update", "chmod"} and destination.exists():
            operation.backup_relpath = backup_existing_file(report.target, backup_root, operation.relpath)
        if operation.kind == "chmod":
            atomic_write_bytes(destination, action_content(operation.action), operation.action.executable)
            if operation.record is not None:
                update_owned_record(operation.record, operation.action)
            print(f"Repaired executable bit: {operation.relpath}")
            print(f"Backup: {operation.backup_relpath}")
            continue

        atomic_write_bytes(destination, action_content(operation.action), operation.action.executable)
        if operation.record is None:
            operation.record = {
                "path": operation.relpath.as_posix(),
                "ownership": "agent-docs-owned",
            }
            files.append(operation.record)
        update_owned_record(operation.record, operation.action)
        if operation.kind == "update":
            print(f"Updated: {operation.relpath}")
            print(f"Backup: {operation.backup_relpath}")
        elif operation.kind == "restore":
            print(f"Restored: {operation.relpath}")
        else:
            print(f"Added: {operation.relpath}")

    manifest["source"] = current_source_metadata(init_module)
    manifest["updated_at"] = utc_timestamp()
    write_audit(backup_root, operations)
    atomic_write_json(report.target / MANIFEST_PATH, manifest)
    print(f"Updated: {MANIFEST_PATH}")


def upgrade(args: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="agent-docs upgrade", description="Safe upgrade preview or tooling-only write mode.")
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument("--dry-run", action="store_true", help="Preview changes without writing. This is the default.")
    mode.add_argument("--write", action="store_true", help="Apply deterministic safe updates.")
    parser.add_argument("--tooling-only", action="store_true", help="Required with --write; limits writes to AGENT-DOCS-owned tooling.")
    parser.add_argument("target", nargs="?", type=Path, default=Path.cwd(), help="Target repository root. Defaults to the current directory.")
    parsed = parser.parse_args(args)
    report = classify_target(parsed.target.expanduser())
    if not parsed.write:
        print_report("upgrade dry-run", report)
        return report_exit_code(report)
    if not parsed.tooling_only:
        print("`agent-docs upgrade --write` requires `--tooling-only`.", file=sys.stderr)
        print("Use `agent-docs upgrade [target]` or `agent-docs upgrade --dry-run [target]` for a read-only preview.", file=sys.stderr)
        return 2

    print_report("upgrade write tooling-only", report)
    if report.has_any(REFUSED_CATEGORIES):
        print("refusing tooling-only write: refused/unknown/incompatible shapes are present", file=sys.stderr)
        return 2

    operations, blocking_drift, manifest, init_module = build_tooling_operations(report)
    if blocking_drift:
        print("refusing tooling-only write: checksum drift/local modification is present", file=sys.stderr)
        for finding in blocking_drift:
            print(f"- {finding.path}: {finding.reason}", file=sys.stderr)
        return 2
    if manifest is None or init_module is None:
        print("refusing tooling-only write: manifest or upstream action set is unavailable", file=sys.stderr)
        return 2
    if not operations:
        print("No tooling-only writes needed.")
        return report_exit_code(report)

    print("Applying tooling-only writes:")
    backup_root = report.target / ".agent-docs/backups" / backup_timestamp()
    backup_refusal = backup_root_refusal(report.target, backup_root)
    if backup_refusal is not None:
        print("refusing tooling-only write: backup path is unsafe", file=sys.stderr)
        print(f"- {backup_refusal.path}: {backup_refusal.reason}", file=sys.stderr)
        return 2
    for operation in operations:
        if operation.kind in {"update", "chmod"}:
            backup_refusal = backup_destination_refusal(report.target, backup_root, operation.relpath)
            if backup_refusal is not None:
                print("refusing tooling-only write: backup path is unsafe", file=sys.stderr)
                print(f"- {backup_refusal.path}: {backup_refusal.reason}", file=sys.stderr)
                return 2
    apply_tooling_operations(report, operations, manifest, init_module, backup_root)
    post_write_report = classify_target(report.target)
    return report_exit_code(post_write_report)


def main(argv: list[str]) -> int:
    if not argv or argv[0] in {"-h", "--help"}:
        print_help()
        return 0
    command, *args = argv
    if command == "docs":
        docs_command = SCRIPT_DIR / "docs-meta"
        if not docs_command.is_file() or not docs_command.stat().st_mode & 0o111:
            print(f"Could not find executable docs-meta next to {Path(__file__).name}.", file=sys.stderr)
            print("Re-run install.sh or use scripts/docs-meta from an AGENT-DOCS checkout.", file=sys.stderr)
            return 1
        return subprocess.call([str(docs_command), *args])
    if command == "init":
        init_command = SCRIPT_DIR / "agent-docs-init"
        if not init_command.is_file() or not init_command.stat().st_mode & 0o111:
            print(f"Could not find executable agent-docs-init next to {Path(__file__).name}.", file=sys.stderr)
            print("Re-run install.sh or use scripts/agent-docs-init from an AGENT-DOCS checkout.", file=sys.stderr)
            return 1
        return subprocess.call([str(init_command), *args])
    if command == "doctor":
        return doctor(args)
    if command == "upgrade":
        return upgrade(args)
    if command == "baseline":
        return baseline(args)
    print(f"Unknown command: {command}", file=sys.stderr)
    print("Run `agent-docs --help` for usage.", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
