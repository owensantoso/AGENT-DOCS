#!/usr/bin/env python3
"""Deterministic metadata helper for agent-friendly docs.

The repo tree is the source of truth. This tool scans Markdown filenames and
frontmatter, then derives next IDs, registries, status tables, and todo views.
"""

from __future__ import annotations

import argparse
import datetime as dt
import os
import re
import subprocess
import sys
from dataclasses import dataclass, field
from pathlib import Path


ID_PATTERNS = {
    "spec": re.compile(r"\bSPEC-(\d{4})\b"),
    "plan": re.compile(r"\bPLAN-(\d{4})\b"),
    "impl": re.compile(r"\bIMPL-(\d{4})-(\d{2})\b"),
    "adr": re.compile(r"\bADR-(\d{4})\b"),
}

TYPE_BY_PREFIX = {
    "SPEC": "spec",
    "PLAN": "plan",
    "IMPL": "implementation-brief",
    "ADR": "adr",
}

ALLOWED_STATUSES = {
    "draft",
    "proposed",
    "ready",
    "in_progress",
    "blocked",
    "completed",
    "implemented",
    "superseded",
}

GENERATED_HEADER = "<!-- Generated by scripts/docs-meta update. Do not edit by hand. -->"


@dataclass
class Doc:
    path: Path
    relpath: str
    frontmatter: dict[str, object]
    content: str
    ids: list[str] = field(default_factory=list)

    @property
    def primary_id(self) -> str:
        value = self.frontmatter.get("id")
        if isinstance(value, str) and value:
            return value
        return self.ids[0] if self.ids else ""

    @property
    def doc_type(self) -> str:
        value = self.frontmatter.get("type")
        if isinstance(value, str) and value:
            return value
        doc_id = self.primary_id
        prefix = doc_id.split("-", 1)[0] if doc_id else ""
        return TYPE_BY_PREFIX.get(prefix, "")

    @property
    def status(self) -> str:
        value = self.frontmatter.get("status")
        return value if isinstance(value, str) else ""

    @property
    def title(self) -> str:
        value = self.frontmatter.get("title")
        if isinstance(value, str) and value:
            return value
        match = re.search(r"^#\s+(.+)$", self.content, re.MULTILINE)
        if match:
            title = match.group(1).strip()
            return re.sub(r"^(SPEC|PLAN|IMPL|ADR)-\d{4}(?:-\d{2})?\s*-\s*", "", title)
        return self.path.stem


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Scan and update docs metadata.")
    parser.add_argument("--root", default="docs", help="Docs root to scan. Default: docs")

    sub = parser.add_subparsers(dest="command", required=True)

    next_cmd = sub.add_parser("next", help="Print next ID for a doc family.")
    next_cmd.add_argument("family", choices=["spec", "plan", "impl", "adr"])
    next_cmd.add_argument("--plan", help="Required for impl IDs, e.g. PLAN-0034")

    new_cmd = sub.add_parser("new", help="Create a new spec, plan, or impl doc.")
    new_cmd.add_argument("family", choices=["spec", "plan", "impl"])
    new_cmd.add_argument("title")
    new_cmd.add_argument("--domain", default="product")
    new_cmd.add_argument("--spec-type", default="feature")
    new_cmd.add_argument("--status", default="draft")
    new_cmd.add_argument("--owner", default="")
    new_cmd.add_argument("--source-type", default="conversation")
    new_cmd.add_argument("--source-link", default="")
    new_cmd.add_argument("--plan", help="Parent plan for impl docs, e.g. PLAN-0034")
    new_cmd.add_argument("--spec", action="append", default=[], help="Related SPEC-* ID. Repeatable.")

    status_cmd = sub.add_parser("status", help="Show doc statuses.")
    status_cmd.add_argument("id", nargs="?")

    set_status_cmd = sub.add_parser("set-status", help="Update a doc status in frontmatter.")
    set_status_cmd.add_argument("id")
    set_status_cmd.add_argument("status", choices=sorted(ALLOWED_STATUSES))

    todos_cmd = sub.add_parser("todos", help="List Markdown task checkboxes.")
    todos_cmd.add_argument("id", nargs="?")
    todos_cmd.add_argument("--all", action="store_true", help="Include completed todos.")

    sub.add_parser("update", help="Regenerate docs registries and todo dashboard.")
    sub.add_parser("check", help="Validate IDs, statuses, and generated docs.")

    return parser.parse_args()


def docs_root(value: str) -> Path:
    root = Path(value)
    if not root.exists() and Path.cwd().name == "docs":
        root = Path.cwd()
    return root


def read_docs(root: Path) -> list[Doc]:
    docs: list[Doc] = []
    if not root.exists():
        return docs
    for path in sorted(root.rglob("*.md")):
        if any(part in {".git", "node_modules", ".generated"} for part in path.parts):
            continue
        text = path.read_text(encoding="utf-8")
        frontmatter, content = parse_frontmatter(text)
        frontmatter_id = frontmatter.get("id")
        ids = find_ids(path.name)
        if isinstance(frontmatter_id, str):
            ids.extend(find_ids(frontmatter_id))
        ids = sorted(set(ids))
        docs.append(Doc(path=path, relpath=path.relative_to(root).as_posix(), frontmatter=frontmatter, content=content, ids=ids))
    return docs


def parse_frontmatter(text: str) -> tuple[dict[str, object], str]:
    if not text.startswith("---\n"):
        return {}, text
    end = text.find("\n---", 4)
    if end == -1:
        return {}, text
    raw = text[4:end].splitlines()
    content = text[end + 4 :].lstrip("\n")
    data: dict[str, object] = {}
    current_key = ""
    for line in raw:
        if not line.strip():
            continue
        if line.startswith("  - ") and current_key:
            value = str(line[4:].strip()).strip('"')
            data.setdefault(current_key, [])
            if isinstance(data[current_key], list):
                data[current_key].append(value)
            continue
        if line.startswith("  ") and current_key:
            continue
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        key = key.strip()
        value = value.strip()
        current_key = key
        if value == "[]":
            data[key] = []
        elif value == "":
            data[key] = ""
        else:
            data[key] = value.strip('"')
    return data, content


def find_ids(text: str) -> list[str]:
    ids: list[str] = []
    for pattern in ID_PATTERNS.values():
        for match in pattern.finditer(text):
            ids.append(match.group(0))
    return ids


def slugify(title: str) -> str:
    slug = title.lower()
    slug = re.sub(r"[^a-z0-9]+", "-", slug)
    return slug.strip("-") or "untitled"


def now_string() -> str:
    now = dt.datetime.now().astimezone()
    zone = now.tzname() or "local"
    offset = now.strftime("%z")
    return now.strftime(f"%Y-%m-%d %H:%M:%S {zone} {offset}")


def git_head() -> str:
    try:
        result = subprocess.run(["git", "rev-parse", "HEAD"], check=True, capture_output=True, text=True)
        return result.stdout.strip()
    except Exception:
        return ""


def next_id(family: str, docs: list[Doc], plan: str | None = None) -> str:
    if family == "impl":
        if not plan or not re.fullmatch(r"PLAN-\d{4}", plan):
            raise SystemExit("--plan PLAN-#### is required for impl IDs")
        plan_num = plan.split("-")[1]
        max_suffix = 0
        for doc in docs:
            for doc_id in doc.ids:
                match = re.fullmatch(rf"IMPL-{plan_num}-(\d{{2}})", doc_id)
                if match:
                    max_suffix = max(max_suffix, int(match.group(1)))
        return f"IMPL-{plan_num}-{max_suffix + 1:02d}"

    pattern = ID_PATTERNS[family]
    max_num = 0
    for doc in docs:
        for doc_id in doc.ids:
            match = pattern.fullmatch(doc_id)
            if match:
                max_num = max(max_num, int(match.group(1)))
    return f"{family.upper()}-{max_num + 1:04d}"


def find_doc(docs: list[Doc], doc_id: str) -> Doc | None:
    for doc in docs:
        if doc.primary_id == doc_id or doc_id in doc.ids:
            return doc
    return None


def new_doc(args: argparse.Namespace, root: Path, docs: list[Doc]) -> Path:
    title = args.title
    slug = slugify(title)
    timestamp = now_string()
    commit = git_head()

    if args.family == "spec":
        doc_id = next_id("spec", docs)
        path = root / args.domain / "specs" / f"{doc_id}-{slug}.md"
        body = spec_doc(doc_id, title, args, timestamp, commit)
    elif args.family == "plan":
        doc_id = next_id("plan", docs)
        path = root / args.domain / "plans" / f"{doc_id}-{slug}" / "plan.md"
        body = plan_doc(doc_id, title, args, timestamp, commit)
    else:
        if not args.plan:
            raise SystemExit("--plan PLAN-#### is required for impl docs")
        doc_id = next_id("impl", docs, args.plan)
        parent = find_doc(docs, args.plan)
        base = parent.path.parent if parent else root / args.domain / "plans" / args.plan
        path = base / f"{doc_id}-{slug}.md"
        body = impl_doc(doc_id, title, args, timestamp, commit)

    if path.exists():
        raise SystemExit(f"Refusing to overwrite existing file: {path}")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(body, encoding="utf-8")
    return path


def yaml_list(values: list[str]) -> str:
    if not values:
        return "[]"
    return "\n" + "\n".join(f"  - {value}" for value in values)


def repo_state_yaml(commit: str) -> str:
    return f"""repo_state:
  based_on_commit: {commit}
  last_reviewed_commit: {commit}"""


def spec_doc(doc_id: str, title: str, args: argparse.Namespace, timestamp: str, commit: str) -> str:
    return f"""---
type: spec
id: {doc_id}
title: {title}
spec_type: {args.spec_type}
domain: {args.domain}
status: {args.status}
created_at: "{timestamp}"
updated_at: "{timestamp}"
owner: {args.owner}
source:
  type: {args.source_type}
  link: {args.source_link}
  notes:
areas: []
related_plans: []
related_issues: []
related_prs: []
related_adrs: []
related_sessions: []
supersedes: []
superseded_by:
{repo_state_yaml(commit)}
---

# {doc_id} - {title}

## Summary

## Problem / Opportunity

## Goals

## Non-Goals

## Current Behavior / Context

## Desired Behavior / Target State

## Requirements

## Open Questions

## Test / Validation Expectations

## Paper Trail
"""


def plan_doc(doc_id: str, title: str, args: argparse.Namespace, timestamp: str, commit: str) -> str:
    return f"""---
type: plan
id: {doc_id}
title: {title}
domain: {args.domain}
status: {args.status}
created_at: "{timestamp}"
updated_at: "{timestamp}"
owner: {args.owner}
areas: []
related_specs:{yaml_list(args.spec)}
related_adrs: []
related_sessions: []
related_issues: []
{repo_state_yaml(commit)}
---

# {doc_id} - {title}

## Goal

## Architecture

## Task Dependencies / Parallelization

## Implementation Tasks

## Validation

## Completion Criteria
"""


def impl_doc(doc_id: str, title: str, args: argparse.Namespace, timestamp: str, commit: str) -> str:
    return f"""---
type: implementation-brief
id: {doc_id}
title: {title}
domain: {args.domain}
status: {args.status}
created_at: "{timestamp}"
updated_at: "{timestamp}"
parent_plan: {args.plan}
task_refs: []
owner: {args.owner}
areas: []
depends_on: []
parallel_with: []
related_specs:{yaml_list(args.spec)}
related_adrs: []
related_sessions: []
related_issues: []
{repo_state_yaml(commit)}
---

# {doc_id} - {title}

## Parent Plan

- {args.plan}

## Task Goal

## Scope

## Execution Steps

## Verification

## Done Checklist

- [ ] Implementation complete
- [ ] Verification complete
"""


def set_status(doc: Doc, status: str) -> None:
    text = doc.path.read_text(encoding="utf-8")
    if not text.startswith("---\n"):
        raise SystemExit(f"{doc.relpath} has no frontmatter")
    end = text.find("\n---", 4)
    if end == -1:
        raise SystemExit(f"{doc.relpath} has malformed frontmatter")
    header = text[: end + 4]
    rest = text[end + 4 :]
    if re.search(r"^status:\s*.*$", header, re.MULTILINE):
        header = re.sub(r"^status:\s*.*$", f"status: {status}", header, flags=re.MULTILINE)
    else:
        header = header.replace("\n---", f"\nstatus: {status}\n---", 1)
    timestamp = now_string()
    if re.search(r"^updated_at:\s*.*$", header, re.MULTILINE):
        header = re.sub(r"^updated_at:\s*.*$", f'updated_at: "{timestamp}"', header, flags=re.MULTILINE)
    if "last_reviewed_commit:" in header:
        header = re.sub(r"^  last_reviewed_commit:\s*.*$", f"  last_reviewed_commit: {git_head()}", header, flags=re.MULTILINE)
    doc.path.write_text(header + rest, encoding="utf-8")


def task_rows(doc: Doc, include_done: bool = False) -> list[tuple[str, int, str, str]]:
    rows: list[tuple[str, int, str, str]] = []
    for idx, line in enumerate(doc.content.splitlines(), start=1):
        match = re.match(r"\s*[-*]\s+\[([ xX])\]\s+(.+)", line)
        if not match:
            continue
        done = match.group(1).lower() == "x"
        if done and not include_done:
            continue
        rows.append(("done" if done else "open", idx, match.group(2).strip(), doc.primary_id or doc.relpath))
    return rows


def specs_markdown(docs: list[Doc]) -> str:
    specs = sorted((doc for doc in docs if doc.primary_id.startswith("SPEC-")), key=lambda d: d.primary_id)
    lines = [
        "# Spec Registry",
        "",
        GENERATED_HEADER,
        "",
        "Global registry for durable specs. The repo tree and frontmatter are the source of truth.",
        "",
        "| ID | Title | Type | Domain | Status | Path | Source |",
        "|---|---|---|---|---|---|---|",
    ]
    for doc in specs:
        lines.append(
            "| {id} | {title} | {typ} | {domain} | {status} | `{path}` | {source} |".format(
                id=doc.primary_id,
                title=doc.title,
                typ=doc.frontmatter.get("spec_type", ""),
                domain=doc.frontmatter.get("domain", ""),
                status=doc.status,
                path=doc.relpath,
                source=doc.frontmatter.get("source", ""),
            )
        )
    lines.append("")
    return "\n".join(lines)


def registry_markdown(docs: list[Doc]) -> str:
    tracked = sorted((doc for doc in docs if doc.primary_id), key=lambda d: d.primary_id)
    lines = [
        "# Docs Registry",
        "",
        GENERATED_HEADER,
        "",
        "| ID | Type | Title | Status | Path |",
        "|---|---|---|---|---|",
    ]
    for doc in tracked:
        lines.append(f"| {doc.primary_id} | {doc.doc_type} | {doc.title} | {doc.status} | `{doc.relpath}` |")
    lines.append("")
    return "\n".join(lines)


def todos_markdown(docs: list[Doc]) -> str:
    rows = []
    for doc in docs:
        rows.extend((doc, row) for row in task_rows(doc))
    lines = [
        "# Docs Todos",
        "",
        GENERATED_HEADER,
        "",
        "| Source | Line | Task |",
        "|---|---:|---|",
    ]
    for doc, (_, line, task, source) in rows:
        lines.append(f"| {source} | {line} | {task} |")
    lines.append("")
    return "\n".join(lines)


def update(root: Path, docs: list[Doc]) -> None:
    (root / "SPECS.md").write_text(specs_markdown(docs), encoding="utf-8")
    (root / "DOCS-REGISTRY.md").write_text(registry_markdown(docs), encoding="utf-8")
    (root / "TODOS.md").write_text(todos_markdown(docs), encoding="utf-8")


def check(root: Path, docs: list[Doc]) -> int:
    errors: list[str] = []
    seen: dict[str, str] = {}
    for doc in docs:
        doc_id = doc.primary_id
        if not doc_id:
            continue
        if doc_id in seen:
            errors.append(f"Duplicate ID {doc_id}: {seen[doc_id]} and {doc.relpath}")
        seen[doc_id] = doc.relpath
        if doc_id not in doc.path.name and doc.path.name != "plan.md":
            errors.append(f"ID {doc_id} is not present in filename: {doc.relpath}")
        if doc.status and doc.status not in ALLOWED_STATUSES:
            errors.append(f"Unknown status {doc.status!r} in {doc.relpath}")

    generated = {
        root / "SPECS.md": specs_markdown(docs),
        root / "DOCS-REGISTRY.md": registry_markdown(docs),
        root / "TODOS.md": todos_markdown(docs),
    }
    for path, expected in generated.items():
        if path.exists() and path.read_text(encoding="utf-8") != expected:
            errors.append(f"Generated file is stale: {path.relative_to(root)}")

    for error in errors:
        print(f"ERROR: {error}", file=sys.stderr)
    return 1 if errors else 0


def main() -> int:
    args = parse_args()
    root = docs_root(args.root)
    docs = read_docs(root)

    if args.command == "next":
        print(next_id(args.family, docs, args.plan))
        return 0
    if args.command == "new":
        path = new_doc(args, root, docs)
        print(path)
        return 0
    if args.command == "status":
        selected = [find_doc(docs, args.id)] if args.id else [doc for doc in docs if doc.primary_id]
        for doc in selected:
            if doc:
                print(f"{doc.primary_id or doc.relpath}\t{doc.status or '(none)'}\t{doc.relpath}")
        return 0
    if args.command == "set-status":
        doc = find_doc(docs, args.id)
        if not doc:
            raise SystemExit(f"No document found for {args.id}")
        set_status(doc, args.status)
        print(f"{args.id}\t{args.status}")
        return 0
    if args.command == "todos":
        selected_docs = [find_doc(docs, args.id)] if args.id else docs
        for doc in selected_docs:
            if not doc:
                continue
            for state, line, task, source in task_rows(doc, include_done=args.all):
                print(f"{state}\t{source}\t{doc.relpath}:{line}\t{task}")
        return 0
    if args.command == "update":
        update(root, docs)
        return 0
    if args.command == "check":
        return check(root, docs)
    raise SystemExit(f"Unknown command: {args.command}")


if __name__ == "__main__":
    raise SystemExit(main())
