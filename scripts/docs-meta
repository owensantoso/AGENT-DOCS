# {doc_id} - {title}

## Goal

## Architecture

## Task Dependencies / Parallelization

## Implementation Tasks

## Validation

## Completion Criteria
"""


def impl_doc(doc_id: str, title: str, args: argparse.Namespace, timestamp: str, commit: str) -> str:
    status = status_for_new(args, "implementation-brief")
