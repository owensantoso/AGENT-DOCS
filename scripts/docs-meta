## Parent Plan

- {args.plan}

## Task Goal

## Scope

## Execution Steps

## Verification

## Done Checklist

- [ ] Implementation complete
- [ ] Verification complete
"""


def adr_doc(doc_id: str, title: str, args: argparse.Namespace, timestamp: str, commit: str) -> str:
    status = status_for_new(args, "adr")
    return f"""---
type: adr
