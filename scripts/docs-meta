{repo_state_yaml(commit)}
---

# {doc_id} - {title}

## Context

## Decision

## Consequences

## Alternatives Considered

## Guardrails
"""


def set_status(doc: Doc, status: str) -> None:
    doc_type = doc.doc_type
    allowed = STATUS_BY_TYPE.get(doc_type, COMMON_STATUSES)
    if status not in allowed:
        raise SystemExit(f"Status {status!r} is not valid for {doc_type or doc.relpath}; choose one of: {', '.join(sorted(allowed))}")
    text = doc.path.read_text(encoding="utf-8")
    if not text.startswith("---\n"):
        raise SystemExit(f"{doc.relpath} has no frontmatter")
    end = text.find("\n---", 4)
    if end == -1:
        raise SystemExit(f"{doc.relpath} has malformed frontmatter")
    header = text[: end + 4]
    rest = text[end + 4 :]
    if re.search(r"^status:[^\n]*$", header, re.MULTILINE):
        header = re.sub(r"^status:[^\n]*$", f"status: {status}", header, flags=re.MULTILINE)
    else:
        header = header.replace("\n---", f"\nstatus: {status}\n---", 1)
    timestamp = now_string()
    if re.search(r"^updated_at:[^\n]*$", header, re.MULTILINE):
        header = re.sub(r"^updated_at:[^\n]*$", f'updated_at: "{timestamp}"', header, flags=re.MULTILINE)
    if "last_reviewed_commit:" in header:
        header = re.sub(r"^  last_reviewed_commit:[^\n]*$", f"  last_reviewed_commit: {git_head()}", header, flags=re.MULTILINE)
    doc.path.write_text(header + rest, encoding="utf-8")


def task_rows(doc: Doc, include_done: bool = False) -> list[tuple[str, int, str, str]]:
    rows: list[tuple[str, int, str, str]] = []
    for idx, line in enumerate(doc.content.splitlines(), start=1):
        match = re.match(r"\s*[-*]\s+\[([ xX])\]\s+(.+)", line)
        if not match:
            continue
        done = match.group(1).lower() == "x"
        if done and not include_done:
            continue
        rows.append(("done" if done else "open", idx, match.group(2).strip(), doc.primary_id or doc.relpath))
    return rows


def field_summary(value: object) -> str:
    if isinstance(value, list):
        return ", ".join(str(item) for item in value)
    if isinstance(value, dict):
        pieces = []
        for key in ("type", "link", "notes"):
            item = value.get(key)
            if item:
                pieces.append(str(item))
        return " / ".join(pieces)
    return str(value) if value else ""


def ideas_markdown(docs: list[Doc]) -> str:
    ideas = sorted((doc for doc in docs if doc.primary_id.startswith("IDEA-")), key=lambda d: d.primary_id)
    lines = [
        "# Idea Registry",
        "",
        GENERATED_HEADER,
        "",
        "Global registry for lightweight ideas. Ideas are captured sparks, not approved specs.",
        "",
        "| ID | Title | Domain | Status | Path | Source | Promoted To |",
        "|---|---|---|---|---|---|---|",
    ]
    for doc in ideas:
        lines.append(
            "| {id} | {title} | {domain} | {status} | `{path}` | {source} | {promoted_to} |".format(
                id=doc.primary_id,
                title=doc.title,
                domain=doc.frontmatter.get("domain", ""),
                status=doc.status,
                path=doc.relpath,
                source=field_summary(doc.frontmatter.get("source", "")),
                promoted_to=field_summary(doc.frontmatter.get("promoted_to", "")),
            )
        )
    lines.append("")
    return "\n".join(lines)


def specs_markdown(docs: list[Doc]) -> str:
    specs = sorted((doc for doc in docs if doc.primary_id.startswith("SPEC-")), key=lambda d: d.primary_id)
    lines = [
        "# Spec Registry",
        "",
        GENERATED_HEADER,
        "",
        "Global registry for durable specs. The repo tree and frontmatter are the source of truth.",
        "",
        "| ID | Title | Type | Domain | Status | Path | Source |",
        "|---|---|---|---|---|---|---|",
    ]
    for doc in specs:
        lines.append(
            "| {id} | {title} | {typ} | {domain} | {status} | `{path}` | {source} |".format(
                id=doc.primary_id,
                title=doc.title,
                typ=doc.frontmatter.get("spec_type", ""),
                domain=doc.frontmatter.get("domain", ""),
                status=doc.status,
                path=doc.relpath,
                source=field_summary(doc.frontmatter.get("source", "")),
            )
        )
    lines.append("")
    return "\n".join(lines)


def registry_markdown(docs: list[Doc]) -> str:
    tracked = sorted((doc for doc in docs if doc.primary_id), key=lambda d: d.primary_id)
    lines = [
        "# Docs Registry",
        "",
        GENERATED_HEADER,
        "",
        "| ID | Type | Title | Status | Path |",
        "|---|---|---|---|---|",
    ]
    for doc in tracked:
        lines.append(f"| {doc.primary_id} | {doc.doc_type} | {doc.title} | {doc.status} | `{doc.relpath}` |")
    lines.append("")
    return "\n".join(lines)


def todos_markdown(docs: list[Doc]) -> str:
    rows = []
    for doc in docs:
        rows.extend((doc, row) for row in task_rows(doc))
    lines = [
        "# Docs Todos",
        "",
        GENERATED_HEADER,
        "",
        "| Source | Line | Task |",
        "|---|---:|---|",
    ]
    for doc, (_, line, task, source) in rows:
        lines.append(f"| {source} | {line} | {task} |")
    lines.append("")
    return "\n".join(lines)


def areas_markdown(docs: list[Doc]) -> str:
    areas = sorted((doc for doc in docs if doc.doc_type == "architecture-area"), key=lambda d: d.primary_id or d.title)
    lines = [
        "# Architecture Area Registry",
        "",
        GENERATED_HEADER,
        "",
        "| ID | Title | Status | Path |",
        "|---|---|---|---|",
    ]
    for doc in areas:
        lines.append(f"| {doc.primary_id} | {doc.title} | {doc.status} | `{doc.relpath}` |")
    lines.append("")
    return "\n".join(lines)


def audit_docs(docs: list[Doc]) -> list[Doc]:
    return sorted((doc for doc in docs if doc.doc_type == "repo-health-audit"), key=lambda d: d.frontmatter.get("audit_ended_at") or d.frontmatter.get("created_at") or d.relpath, reverse=True)


def audits_markdown(docs: list[Doc]) -> str:
    audits = audit_docs(docs)
    lines = [
        "# Repo Health Audits",
        "",
        GENERATED_HEADER,
        "",
        "Generated index of repo-health audits. Audits are periodic receipts for docs, architecture, maintenance, duplication/refactor, tests, tooling, and other project hygiene checks.",
        "",
        "| Date | Status | Title | Scope | Path |",
        "|---|---|---|---|---|",
    ]
    for doc in audits:
        ended_at = doc.frontmatter.get("audit_ended_at") or doc.frontmatter.get("created_at", "")
        date = str(ended_at).split(" ", 1)[0] if ended_at else ""
        lines.append(f"| {date} | {doc.status} | {doc.title} | {field_summary(doc.frontmatter.get('scope', ''))} | `{doc.relpath}` |")
    lines.append("")
    return "\n".join(lines)


def sequence_value(doc: Doc) -> str:
    sequence = doc.frontmatter.get("sequence")
    if isinstance(sequence, dict):
        value = sequence.get("roadmap") or sequence.get("sort_key")
        return str(value) if value else ""
    value = doc.frontmatter.get("roadmap_sequence")
    return str(value) if value else ""


def sort_sequence(value: str) -> tuple:
    if not value:
        return ((1, "zzzzzz"),)
    parts: list[tuple[int, object]] = []
    for part in re.split(r"([0-9]+)", value):
        if part == "":
            continue
        if part.isdigit():
            parts.append((0, int(part)))
        else:
            parts.append((1, part.lower()))
    return tuple(parts)


def roadmap_rows(docs: list[Doc]) -> list[dict[str, str]]:
    plans = sorted((doc for doc in docs if doc.doc_type == "plan"), key=lambda d: (sort_sequence(sequence_value(d)), d.primary_id))
    rows: list[dict[str, str]] = []
    for doc in plans:
        sequence = doc.frontmatter.get("sequence")
        after = before = lane = ""
        if isinstance(sequence, dict):
            after = field_summary(sequence.get("after", ""))
            before = field_summary(sequence.get("before", ""))
            lane = str(sequence.get("lane", "") or "")
        rows.append(
            {
                "sequence": sequence_value(doc),
                "id": doc.primary_id,
                "title": doc.title,
                "status": doc.status,
                "domain": str(doc.frontmatter.get("domain", "")),
                "lane": lane,
                "after": after,
                "before": before,
                "path": doc.relpath,
            }
        )
    return rows


def roadmap_markdown(docs: list[Doc]) -> str:
    rows = roadmap_rows(docs)
    lines = [
        "# Roadmap View",
        "",
        GENERATED_HEADER,
        "",
        "Generated plan-order view. `PLAN-*` IDs are stable identity; `sequence` frontmatter owns execution order.",
        "",
        "| Sequence | Plan | Title | Status | Domain | Lane | After | Before | Path |",
        "|---|---|---|---|---|---|---|---|---|",
    ]
    for row in rows:
        lines.append(
            "| {sequence} | {id} | {title} | {status} | {domain} | {lane} | {after} | {before} | `{path}` |".format(**row)
        )
    if not rows:
        lines.append("|  |  | No plans found. |  |  |  |  |  |  |")
    lines.append("")
    return "\n".join(lines)


def parse_timestamp(value: object) -> dt.datetime | None:
    if not isinstance(value, str) or not value:
        return None
    match = re.search(r"(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})(?: [A-Za-z0-9_+/-]+)? ([+-]\d{4})", value)
    if match:
        try:
            return dt.datetime.strptime(f"{match.group(1)} {match.group(2)}", "%Y-%m-%d %H:%M:%S %z")
        except ValueError:
            return None
    try:
        parsed = dt.datetime.fromisoformat(value)
        if parsed.tzinfo is None:
            parsed = parsed.replace(tzinfo=dt.datetime.now().astimezone().tzinfo)
        return parsed
    except ValueError:
        return None


def nested_value(mapping: dict[str, object], key: str, child_key: str) -> str:
    value = mapping.get(key)
    if isinstance(value, dict):
        child = value.get(child_key)
        return child if isinstance(child, str) else ""
    return ""


def health_issues(docs: list[Doc], stale_days: int, commit_threshold: int, audit_days: int) -> list[HealthIssue]:
    issues: list[HealthIssue] = []
    now = dt.datetime.now().astimezone()
    current_head = git_head()
    freshness_types = {
        "current-state",
        "onboarding",
        "roadmap",
        "architecture-overview",
        "architecture-area",
        "codebase-map",
        "data-seams",
        "testing-guide",
    }
    work_statuses = {"captured", "exploring", "draft", "proposed", "ready", "in_progress", "in-progress", "blocked"}
    archived_statuses = {"archived", "rejected", "superseded"}
    audits = audit_docs(docs)
    completed_audits = [doc for doc in audits if doc.status == "completed"]
    if not completed_audits:
        issues.append(
            HealthIssue(
                "info",
                "missing-repo-health-audit",
                "repo-health/audits/",
                "No completed repo-health audit found.",
                "Create one after periodic docs, architecture, maintenance, tests, and tooling checks.",
            )
        )
    else:
        last_audit = completed_audits[0]
        audit_time = parse_timestamp(last_audit.frontmatter.get("audit_ended_at") or last_audit.frontmatter.get("updated_at"))
        if audit_time:
            audit_age = (now - audit_time).days
            if audit_age >= audit_days:
                issues.append(
                    HealthIssue(
                        "warn",
                        "repo-health-audit-due",
                        last_audit.relpath,
                        f"Last completed repo-health audit was {audit_age} days ago.",
                        f"Threshold: {audit_days} days",
                    )
                )

    for doc in docs:
        doc_type = doc.doc_type
        if not doc_type or doc.status in archived_statuses:
            continue

        updated_at = parse_timestamp(doc.frontmatter.get("updated_at"))
        age_days = (now - updated_at).days if updated_at else None
        label = doc.primary_id or doc.relpath

        if doc_type in freshness_types:
            if age_days is None:
                issues.append(HealthIssue("warn", "missing-updated-at", doc.relpath, f"{label} has no parseable updated_at timestamp."))
            elif age_days >= stale_days:
                issues.append(
                    HealthIssue(
                        "warn",
                        "stale-by-time",
                        doc.relpath,
                        f"{label} has not been updated in {age_days} days.",
                        f"Threshold: {stale_days} days",
                    )
                )

        if doc.status in work_statuses and age_days is not None and age_days >= stale_days:
            severity = "warn" if doc.status == "blocked" else "info"
            issues.append(
                HealthIssue(
                    severity,
                    "open-work-aging",
                    doc.relpath,
                    f"{label} is {doc.status} and has not been updated in {age_days} days.",
                    f"Review whether the status still reflects reality.",
                )
            )

        reviewed_commit = nested_value(doc.frontmatter, "repo_state", "last_reviewed_commit")
        if "repo_state" in doc.frontmatter and not reviewed_commit:
            issues.append(HealthIssue("info", "missing-review-commit", doc.relpath, f"{label} has repo_state but no last_reviewed_commit."))
        elif reviewed_commit and current_head and reviewed_commit != current_head:
            count = git_commit_count_since(reviewed_commit)
            if count is not None and count >= commit_threshold:
                issues.append(
                    HealthIssue(
                        "warn",
                        "stale-by-commit",
                        doc.relpath,
                        f"{label} was last reviewed {count} commits ago.",
                        f"last_reviewed_commit: {reviewed_commit}",
                    )
                )

    return issues


def health_markdown(issues: list[HealthIssue], stale_days: int, commit_threshold: int, audit_days: int) -> str:
    lines = [
        "# Docs Health",
        "",
        GENERATED_HEADER,
        "",
        "Advisory review queue for docs that may be stale or worth checking. This is not a correctness report; use `scripts/docs-meta check` for deterministic validation.",
        "",
        f"- Time threshold: {stale_days} days",
        f"- Commit threshold: {commit_threshold} commits since `repo_state.last_reviewed_commit`",
        f"- Audit threshold: {audit_days} days since last completed repo-health audit",
        "",
        "| Severity | Code | Doc | Message | Detail |",
        "|---|---|---|---|---|",
    ]
    for issue in issues:
        lines.append(f"| {issue.severity} | {issue.code} | `{issue.doc}` | {issue.message} | {issue.detail} |")
    if not issues:
        lines.append("| ok | none |  | No docs health issues found. |  |")
    lines.append("")
    return "\n".join(lines)


def health_text(issues: list[HealthIssue]) -> str:
    if not issues:
        return "No docs health issues found."
    return "\n".join(
        f"{issue.severity.upper()}\t{issue.code}\t{issue.doc}\t{issue.message}" + (f"\t{issue.detail}" if issue.detail else "")
        for issue in issues
    )


def update(root: Path, docs: list[Doc]) -> None:
    if any(doc.primary_id.startswith("IDEA-") for doc in docs) or (root / "IDEAS.md").exists():
        (root / "IDEAS.md").write_text(ideas_markdown(docs), encoding="utf-8")
    (root / "SPECS.md").write_text(specs_markdown(docs), encoding="utf-8")
    (root / "DOCS-REGISTRY.md").write_text(registry_markdown(docs), encoding="utf-8")
    (root / "TODOS.md").write_text(todos_markdown(docs), encoding="utf-8")
    if any(doc.doc_type == "repo-health-audit" for doc in docs) or (root / "AUDITS.md").exists():
        (root / "AUDITS.md").write_text(audits_markdown(docs), encoding="utf-8")
    if any(doc.doc_type == "plan" for doc in docs) or (root / "ROADMAP-VIEW.md").exists():
        (root / "ROADMAP-VIEW.md").write_text(roadmap_markdown(docs), encoding="utf-8")
    if any(doc.doc_type == "architecture-area" for doc in docs) or (root / "AREAS.md").exists():
        (root / "AREAS.md").write_text(areas_markdown(docs), encoding="utf-8")


def check(root: Path, docs: list[Doc]) -> int:
    errors: list[str] = []
    seen: dict[str, str] = {}
    for doc in docs:
        doc_id = doc.primary_id
        if not doc_id:
            continue
        if doc_id in seen:
            errors.append(f"Duplicate ID {doc_id}: {seen[doc_id]} and {doc.relpath}")
        seen[doc_id] = doc.relpath
        if doc_id not in doc.path.name and doc.path.name != "plan.md":
            errors.append(f"ID {doc_id} is not present in filename: {doc.relpath}")
        if doc.path.name == "plan.md" and doc_id.startswith("PLAN-") and doc_id not in doc.path.parent.name:
            errors.append(f"Plan ID {doc_id} is not present in parent folder name: {doc.relpath}")
        errors.extend(validate_frontmatter(doc))

    generated = {
        root / "SPECS.md": specs_markdown(docs),
        root / "DOCS-REGISTRY.md": registry_markdown(docs),
        root / "TODOS.md": todos_markdown(docs),
    }
    if any(doc.primary_id.startswith("IDEA-") for doc in docs) or (root / "IDEAS.md").exists():
        generated[root / "IDEAS.md"] = ideas_markdown(docs)
    if any(doc.doc_type == "repo-health-audit" for doc in docs) or (root / "AUDITS.md").exists():
        generated[root / "AUDITS.md"] = audits_markdown(docs)
    if any(doc.doc_type == "plan" for doc in docs) or (root / "ROADMAP-VIEW.md").exists():
        generated[root / "ROADMAP-VIEW.md"] = roadmap_markdown(docs)
    if any(doc.doc_type == "architecture-area" for doc in docs) or (root / "AREAS.md").exists():
        generated[root / "AREAS.md"] = areas_markdown(docs)
    for path, expected in generated.items():
        if path.exists() and path.read_text(encoding="utf-8") != expected:
            errors.append(f"Generated file is stale: {path.relative_to(root)}")

    for error in errors:
        print(f"ERROR: {error}", file=sys.stderr)
    return 1 if errors else 0


def validate_frontmatter(doc: Doc) -> list[str]:
    errors: list[str] = []
    doc_type = doc.doc_type
    if not doc_type:
        return errors
    if doc_type not in KNOWN_DOC_TYPES:
        errors.append(f"Unknown frontmatter type {doc_type!r} in {doc.relpath}")
        return errors

    required = REQUIRED_FIELDS_BY_TYPE.get(doc_type, set())
    missing = sorted(field for field in required if field not in doc.frontmatter)
    for field in missing:
        errors.append(f"Missing frontmatter field {field!r} in {doc.relpath}")

    allowed_statuses = STATUS_BY_TYPE.get(doc_type, COMMON_STATUSES)
    if doc.status and doc.status not in allowed_statuses:
        errors.append(f"Unknown status {doc.status!r} for type {doc_type!r} in {doc.relpath}")

    if doc_type == "architecture-area":
        doc_id = doc.primary_id
        if doc_id and doc.path.stem != doc_id:
            errors.append(f"Architecture area ID {doc_id} must match filename stem in {doc.relpath}")

    frontmatter_id = doc.frontmatter.get("id")
    if isinstance(frontmatter_id, str) and frontmatter_id:
        filename_ids = set(find_ids(doc.path.name))
        if doc.path.name == "plan.md":
            filename_ids.update(find_ids(doc.path.parent.name))
        family = frontmatter_id.split("-", 1)[0]
        mismatches = sorted(doc_id for doc_id in filename_ids if doc_id.startswith(f"{family}-") and doc_id != frontmatter_id)
        for mismatch in mismatches:
            errors.append(f"Frontmatter ID {frontmatter_id} conflicts with filename ID {mismatch} in {doc.relpath}")

    if doc_type == "implementation-brief":
        parent = doc.frontmatter.get("parent_plan")
        doc_id = doc.primary_id
        if isinstance(parent, str) and parent and doc_id.startswith("IMPL-"):
            expected = f"IMPL-{parent.split('-')[-1]}-"
            if not doc_id.startswith(expected):
                errors.append(f"Implementation ID {doc_id} does not match parent_plan {parent} in {doc.relpath}")

    return errors


def main() -> int:
    args = parse_args()
    root = docs_root(args.root)
    docs = read_docs(root)

    if args.command == "next":
        print(next_id(args.family, docs, args.plan))
        return 0
    if args.command == "new":
        path = new_doc(args, root, docs)
        print(path)
        return 0
    if args.command == "status":
        selected = [find_doc(docs, args.id)] if args.id else [doc for doc in docs if doc.primary_id]
        for doc in selected:
            if doc:
                print(f"{doc.primary_id or doc.relpath}\t{doc.status or '(none)'}\t{doc.relpath}")
        return 0
    if args.command == "set-status":
        doc = find_doc(docs, args.id)
        if not doc:
            raise SystemExit(f"No document found for {args.id}")
        set_status(doc, args.status)
        print(f"{args.id}\t{args.status}")
        return 0
    if args.command == "todos":
        selected_docs = [find_doc(docs, args.id)] if args.id else docs
        for doc in selected_docs:
            if not doc:
                continue
            for state, line, task, source in task_rows(doc, include_done=args.all):
                print(f"{state}\t{source}\t{doc.relpath}:{line}\t{task}")
        return 0
    if args.command == "update":
        update(root, docs)
        return 0
    if args.command == "check":
        return check(root, docs)
    if args.command == "health":
        issues = health_issues(docs, args.stale_days, args.commit_threshold, args.audit_days)
        if args.write:
            (root / "HEALTH.md").write_text(health_markdown(issues, args.stale_days, args.commit_threshold, args.audit_days), encoding="utf-8")
        if args.json:
            print(json.dumps([issue.__dict__ for issue in issues], indent=2))
        else:
            print(health_text(issues))
        return 0
    if args.command == "roadmap":
        rows = roadmap_rows(docs)
        if args.write:
            (root / "ROADMAP-VIEW.md").write_text(roadmap_markdown(docs), encoding="utf-8")
        if args.json:
            print(json.dumps(rows, indent=2))
        else:
            print(roadmap_markdown(docs))
        return 0
    raise SystemExit(f"Unknown command: {args.command}")


if __name__ == "__main__":
    raise SystemExit(main())
